<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <style>
      body { font-family: Arial, sans-serif; margin: 0; background: #f5f7fb; color: #223; }
      .container { max-width: 900px; margin: 40px auto; background: white; padding: 24px; border-radius: 12px; box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
      h1 { margin-top: 0; }
      .actions { margin-bottom: 20px; }
      .btn { display: inline-block; padding: 10px 14px; background: #2563eb; color: white; text-decoration: none; border-radius: 8px; }
      .btn.secondary { background: #4b5563; margin-left: 8px; }
      table { width: 100%; border-collapse: collapse; margin-top: 12px; }
      th, td { padding: 12px; border-bottom: 1px solid #e5e7eb; text-align: left; }
      form { display: inline; }
      .danger { background: #dc2626; }
    </style>
  </head>
  <body>
    <main class="container">
      <h1><%= title %></h1>
      <div class="actions">
        <a class="btn" href="/students/new">Tambah Mahasiswa</a>
      </div>

      <% if (students.length === 0) { %>
        <p>Belum ada data mahasiswa.</p>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th>Nama</th>
              <th>NIM</th>
              <th>Jurusan</th>
              <th>Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% students.forEach((student) => { %>
              <tr>
                <td><%= student.nama %></td>
                <td><%= student.nim %></td>
                <td><%= student.jurusan %></td>
                <td>
                  <a class="btn secondary" href="/students/<%= student.id %>/edit">Edit</a>
                  <form action="/students/<%= student.id %>/delete" method="post" style="display:inline;">
                    <button class="btn danger" type="submit">Hapus</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </main>
  </body>
</html>
